{
  "name": "digiflazz-next",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "prisma generate && next build",
    "start": "next start -p 3005",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed": "node prisma/seed.mjs",
    "update": "git pull && npm install && prisma generate && prisma db push && npm run build && pm2 restart digiflazz-next --update-env",
    "update:dev": "git pull && npm install && prisma generate && prisma db push && npm run dev"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "jose": "5.9.6",
    "lucide-react": "0.456.0",
    "next": "^14.2.33",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.13.3",
    "undici": "6.21.0"
  },
  "devDependencies": {
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.15"
  },
  "engines": {
    "node": ">=18.18"
  }
}
